{
  "app": {
    "name": "Equity Analyst",
    "id": "com.equityanalyst.app",
    "version": "0.1.0",
    "description": "Advanced stock analysis and monitoring platform",
    "author": "Your Organization"
  },
  "build": {
    "targets": {
      "linux": ["deb", "rpm", "appimage"],
      "windows": ["exe", "msi"],
      "macos": ["dmg"]
    },
    "pythonVersion": "3.8",
    "nodeVersion": "16",
    "pyinstallerArgs": {
      "onefile": true,
      "console": false,
      "hiddenImports": [
        "uvicorn",
        "uvicorn.protocols",
        "uvicorn.protocols.http",
        "uvicorn.protocols.websockets",
        "yfinance",
        "pandas_ta"
      ]
    }
  },
  "backend": {
    "name": "fastapi-server",
    "entry": "backend/main.py",
    "port": 8000,
    "host": "127.0.0.1"
  },
  "frontend": {
    "framework": "React",
    "bundler": "Vite",
    "typescript": true,
    "css": "Tailwind"
  },
  "distribution": {
    "outputDir": "build/output",
    "signArtifacts": false,
    "uploadOnComplete": false,
    "uploadEndpoint": "",
    "keepBuildArtifacts": true
  },
  "performance": {
    "parallelBuilds": true,
    "cacheDependencies": true,
    "stripBinaries": true,
    "compressArtifacts": false
  }
}
